# RhomScripts .gitignore
# Autor: Rhomdur
# Versión: 1.0

# ============================================================================
# Archivos de sistema operativo
# ============================================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================================
# Archivos de Mudlet
# ============================================================================
*.mpackage
*.xml

# ============================================================================
# Logs y temporales
# ============================================================================
*.log
*.tmp
logs/
temp/

# ============================================================================
# Backups
# ============================================================================
*.bak
*.backup
*~

# ============================================================================
# Archivos de usuario (personalizados)
# ============================================================================
config/user_*.conf
config/personal.conf

# ============================================================================
# Tests y coverage
# ============================================================================
coverage/
.luacov

# ============================================================================
# IDEs y editores
# ============================================================================
.vscode/
.idea/
*.swp
*.swo

# ============================================================================
# NO ignorar estructura base
# ============================================================================
!.gitkeep
